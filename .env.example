# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
# Supports PostgreSQL, MySQL, SQLite (see Better Auth adapter docs)
DATABASE_URL=

# ─── OAuth Providers (optional — add only what you use) ───────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Add more providers here as needed:
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
