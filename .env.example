# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, local Docker, etc.)
DATABASE_URL=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Leave empty to use console mock in development — emails are logged, not sent.
# Sign up at https://resend.com and verify your domain to send real emails.
RESEND_API_KEY=
# Defaults to noreply@<your-domain> if not set
EMAIL_FROM=

# ─── OAuth Providers (optional — add only what you use) ───────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Add more providers as needed:
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ─── Passkeys (WebAuthn) ─────────────────────────────────────────────────────
# Must match your domain exactly. In production, use your real domain.
# Defaults to "localhost" / "http://localhost:3000" if not set.
# PASSKEY_RP_ID=localhost
# PASSKEY_RP_NAME=MyApp
# PASSKEY_ORIGIN=http://localhost:3000

# ─── Stripe (optional — billing is disabled if not set) ───────────────────────
# Sign up at https://stripe.com. Use test keys (sk_test_...) in development.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create products in your Stripe dashboard and paste IDs here
# Leave empty to keep the free plan only.
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
